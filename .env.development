# 【开发】环境变量

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# 前端端口
VITE_PORT = 5173

# API 请求基础路径（开发环境使用 Vite 代理，设为空字符串避免双 /api 前缀）
VITE_API_BASE_URL =

# 访问模式（前端控制权限）
VITE_ACCESS_MODE = frontend

# 代理目标地址（开发环境通过 Vite 代理转发请求到此地址，解决跨域问题）
VITE_API_PROXY_URL = http://127.0.0.1:5174

# Delete console
VITE_DROP_CONSOLE = false